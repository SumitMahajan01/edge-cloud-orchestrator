{
  "dashboard": {
    "id": null,
    "title": "EdgeCloud Orchestrator - Overview",
    "tags": ["edgecloud", "overview"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Tasks Created (per minute)",
        "type": "stat",
        "targets": [
          {
            "expr": "rate(edgecloud_tasks_created_total[1m]) * 60",
            "legendFormat": "Tasks/min"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Task Success Rate",
        "type": "gauge",
        "targets": [
          {
            "expr": "sum(rate(edgecloud_tasks_completed_total{status=\"COMPLETED\"}[5m])) / sum(rate(edgecloud_tasks_completed_total[5m]))",
            "legendFormat": "Success Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                {"color": "red", "value": 0},
                {"color": "yellow", "value": 0.95},
                {"color": "green", "value": 0.99}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Active Nodes",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(edgecloud_active_nodes{status=\"ONLINE\"})",
            "legendFormat": "Online Nodes"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Scheduler Leader",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(edgecloud_scheduler_leader)",
            "legendFormat": "Leader Count"
          }
        ],
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Task Duration (p95)",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(edgecloud_task_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95 Duration"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 6,
        "title": "Scheduling Latency",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(edgecloud_scheduling_duration_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95 Latency"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 7,
        "title": "Node CPU Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "avg(edgecloud_node_cpu_usage_percent) by (region)",
            "legendFormat": "{{region}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
      },
      {
        "id": 8,
        "title": "Node Memory Usage",
        "type": "graph",
        "targets": [
          {
            "expr": "avg(edgecloud_node_memory_usage_percent) by (region)",
            "legendFormat": "{{region}}"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
      }
    ]
  }
}
