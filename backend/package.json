{
  "name": "edge-cloud-orchestrator-backend",
  "version": "1.0.0",
  "description": "Production backend for Edge-Cloud Compute Orchestrator",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "generate": "prisma generate",
    "seed": "tsx src/database/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@edgecloud/circuit-breaker": "workspace:*",
    "@edgecloud/event-bus": "workspace:*",
    "@edgecloud/ml-scheduler": "workspace:*",
    "@edgecloud/outbox": "workspace:*",
    "@edgecloud/saga": "workspace:*",
    "@edgecloud/shared-kernel": "workspace:*",
    "@fastify/cookie": "^9.2.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.0",
    "@fastify/swagger-ui": "^4.0.0",
    "@kubernetes/client-node": "^1.4.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/instrumentation-fastify": "^0.57.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/instrumentation-pg": "^0.65.0",
    "@opentelemetry/instrumentation-redis": "^0.61.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "^5.14.0",
    "@types/jsonwebtoken": "^9.0.10",
    "amqplib": "^0.10.4",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "eventemitter3": "^5.0.0",
    "fastify": "^4.27.0",
    "kafkajs": "^2.2.4",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prom-client": "^15.0.0",
    "uuid": "^9.0.1",
    "ws": "^8.17.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@fastify/swagger": "^8.15.0",
    "@fastify/websocket": "^8.3.1",
    "@types/amqplib": "^0.10.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.37",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "prisma": "^5.14.0",
    "tsx": "^4.11.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
