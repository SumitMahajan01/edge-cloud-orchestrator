# =============================================================================
# Edge-Cloud Orchestrator - Production Environment Template
# =============================================================================
# Copy this file to .env.production and fill in the values
# =============================================================================

# =============================================================================
# CORE SETTINGS
# =============================================================================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# =============================================================================
# DATABASE
# =============================================================================
POSTGRES_USER=edgecloud_admin
POSTGRES_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>
POSTGRES_DB=edge_cloud
DATABASE_URL=postgresql://edgecloud_admin:<CHANGE_ME>@postgres:5432/edge_cloud?schema=public
DATABASE_READ_URL=  # Optional: read replica URL

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://:<CHANGE_ME_REDIS_PASSWORD>@redis:6379
REDIS_PASSWORD=<CHANGE_ME_REDIS_PASSWORD>

# =============================================================================
# RABBITMQ
# =============================================================================
RABBITMQ_USER=edgecloud
RABBITMQ_PASSWORD=<CHANGE_ME_RABBITMQ_PASSWORD>
RABBITMQ_URL=amqp://edgecloud:<CHANGE_ME>@rabbitmq:5672

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
JWT_SECRET=<CHANGE_ME_256_BIT_SECRET>
JWT_EXPIRES_IN=15m
COOKIE_SECRET=<CHANGE_ME_COOKIE_SECRET>

# =============================================================================
# SECURITY - mTLS (REQUIRED FOR PRODUCTION)
# =============================================================================
# Enable mutual TLS for edge agent authentication
ENABLE_MTLS=true
TLS_CERTS_PATH=/etc/edgecloud

# Server certificate paths
TLS_CERT_PATH=/etc/edgecloud/server.crt
TLS_KEY_PATH=/etc/edgecloud/server.key
TLS_CA_PATH=/etc/edgecloud/ca.crt

# Force HTTPS (redirect HTTP to HTTPS)
FORCE_HTTPS=true

# HSTS settings
HSTS_MAX_AGE=31536000

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=https://your-frontend.com,https://admin.your-frontend.com

# =============================================================================
# EDGE AGENTS
# =============================================================================
ORCHESTRATOR_URL=https://api.your-domain.com
BACKEND_REPLICAS=2

# Edge agent API keys (one per agent)
EDGE_AGENT_1_API_KEY=<CHANGE_ME_AGENT_1_KEY>
EDGE_AGENT_2_API_KEY=<CHANGE_ME_AGENT_2_KEY>

# =============================================================================
# GRAFANA
# =============================================================================
GRAFANA_ROOT_URL=https://grafana.your-domain.com
GRAFANA_COOKIE_SECURE=true

# =============================================================================
# MONITORING
# =============================================================================
PROMETHEUS_RETENTION=15d

# =============================================================================
# SECRETS GENERATION GUIDE
# =============================================================================
# Generate strong secrets with these commands:
#
# JWT_SECRET (256-bit):
#   openssl rand -base64 32
#
# POSTGRES_PASSWORD (strong password):
#   openssl rand -base64 24
#
# REDIS_PASSWORD:
#   openssl rand -base64 24
#
# RABBITMQ_PASSWORD:
#   openssl rand -base64 24
#
# COOKIE_SECRET:
#   openssl rand -base64 32
#
# Edge Agent API Keys:
#   echo "ec_$(openssl rand -hex 32)"

# =============================================================================
# CERTIFICATE GENERATION
# =============================================================================
# Generate mTLS certificates:
#
# cd backend
# ./generate-certs.sh
#
# Or manually with OpenSSL:
#
# # CA Certificate
# openssl genrsa -out ca.key 4096
# openssl req -new -x509 -days 3650 -key ca.key -out ca.crt \
#   -subj "/C=US/O=EdgeCloud/OU=CA/CN=EdgeCloud-CA"
#
# # Server Certificate
# openssl genrsa -out server.key 4096
# openssl req -new -key server.key -out server.csr \
#   -subj "/C=US/O=EdgeCloud/OU=Server/CN=api.your-domain.com"
# openssl x509 -req -days 365 -in server.csr -CA ca.crt -CAkey ca.key \
#   -CAcreateserial -out server.crt
#
# # Agent Certificate (repeat for each agent)
# openssl genrsa -out agent.key 4096
# openssl req -new -key agent.key -out agent.csr \
#   -subj "/C=US/O=EdgeCloud/OU=Edge Nodes/CN=edge-agent-1"
# openssl x509 -req -days 90 -in agent.csr -CA ca.crt -CAkey ca.key \
#   -CAcreateserial -out agent.crt -extfile <(echo "extendedKeyUsage=clientAuth")
