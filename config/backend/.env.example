# Environment Configuration
# Copy this to .env and fill in your values

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (with connection pooling)
# connection_limit: max connections in pool
# pool_timeout: seconds to wait for available connection
# connect_timeout: seconds to establish connection
DATABASE_URL="postgresql://postgres:password@localhost:5432/edge_cloud?schema=public&connection_limit=20&pool_timeout=30&connect_timeout=10"

# Redis
REDIS_URL="redis://localhost:6379"

# RabbitMQ
RABBITMQ_URL="amqp://localhost:5672"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key

# mTLS
MTLS_ENABLED=true
MTLS_CA_CERT=./certs/ca.crt
MTLS_SERVER_CERT=./certs/server.crt
MTLS_SERVER_KEY=./certs/server.key

# Edge Agent
EDGE_AGENT_DEFAULT_PORT=4001
EDGE_AGENT_HEARTBEAT_INTERVAL=5000
EDGE_AGENT_TIMEOUT=30000
EDGE_AGENT_REQUEST_TIMEOUT=30000
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIME=60000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090

# OpenTelemetry (Distributed Tracing)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=edge-cloud-orchestrator

# External APIs
CARBON_API_KEY=
CARBON_API_URL=https://api.electricitymap.org/v3
