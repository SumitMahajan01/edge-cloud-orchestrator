# Development Environment Configuration
# API Gateway URL (nginx proxy in development)
VITE_API_URL=http://localhost:5000

# Direct microservice URLs (for development)
VITE_TASK_SERVICE_URL=http://localhost:5010
VITE_NODE_SERVICE_URL=http://localhost:5011
VITE_SCHEDULER_SERVICE_URL=http://localhost:5003
VITE_WS_URL=ws://localhost:5004/ws
VITE_BACKEND_URL=http://localhost:5000

# Feature flags
VITE_ENABLE_WEBSOCKET=true
VITE_ENABLE_METRICS=true
VITE_ENABLE_TRACING=false
