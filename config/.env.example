# ==========================================
# Edge-Cloud Orchestrator Environment Configuration
# ==========================================

# Application
NODE_ENV=production
SERVICE_NAME=edgecloud-orchestrator
SERVICE_VERSION=2.0.0

# ==========================================
# Database (CockroachDB)
# ==========================================
DATABASE_HOST=localhost
DATABASE_PORT=26257
DATABASE_NAME=edgecloud
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_SSL=false
DATABASE_POOL_SIZE=20

# ==========================================
# Kafka
# ==========================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=edgecloud-service

# ==========================================
# Redis (Caching & Rate Limiting)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# HashiCorp Vault
# ==========================================
VAULT_ADDRESS=http://localhost:8200
VAULT_TOKEN=dev-token
# OR use AppRole:
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=

# ==========================================
# Observability
# ==========================================
# Prometheus
PROMETHEUS_PORT=9090
METRICS_ENABLED=true

# Jaeger (Distributed Tracing)
JAEGER_ENDPOINT=http://localhost:14268/api/traces
TRACING_ENABLED=true
TRACING_SAMPLING_RATE=1.0

# ==========================================
# Scheduler (RAFT)
# ==========================================
SCHEDULER_NODE_ID=scheduler-1
SCHEDULER_RAFT_PORT=7001
SCHEDULER_RAFT_PEERS=scheduler-2:localhost:7002,scheduler-3:localhost:7003

# ==========================================
# Multi-Region
# ==========================================
REGION=us-east
PRIMARY_REGION=us-east
REGIONS=us-east,us-west,eu-west,ap-south

# ==========================================
# Security
# ==========================================
JWT_SECRET=your-jwt-secret-here
API_KEY_SALT=your-api-key-salt
ENCRYPTION_KEY=your-encryption-key

# ==========================================
# Service URLs (Internal)
# ==========================================
TASK_SERVICE_URL=http://task-service:3001
NODE_SERVICE_URL=http://node-service:3002
SCHEDULER_SERVICE_URL=http://scheduler-service:3003

# ==========================================
# Backup & Recovery
# ==========================================
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7
BACKUP_LOCATION=/backups

# ==========================================
# Feature Flags
# ==========================================
ENABLE_ML_SCHEDULER=true
ENABLE_GANG_SCHEDULING=true
ENABLE_RESOURCE_RESERVATIONS=true
ENABLE_CHAOS_ENGINEERING=false
